# Root env — used by docker-compose for variable substitution and to configure
# the containers. Copy to .env before running `docker compose up`.

# Postgres container
POSTGRES_USER=rate_limiter
POSTGRES_PASSWORD=rate_limiter
POSTGRES_DB=rate_limiter

# Backend
ADMIN_API_KEY=change-me-in-production

# Frontend build — the browser calls the backend at this URL
VITE_API_URL=http://localhost:8000
